{
  "name": "asap-react-scaffold",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sandpack:css": "node scripts/build-sandpack-css.mjs",
    "sandpack:css:watch": "node scripts/build-sandpack-css.mjs --watch",
    "build": "npm install --legacy-peer-deps && tsc -b && vite build && node scripts/post-build.cjs",
    "build:offline": "npm run build",
    "start:offline": "npm run build && serve -s dist -l 3000",
    "typecheck:all": "tsc -p tsconfig.app.full.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,cjs,mjs,json,css,scss,md,mdx}\" \"service/**/*.{ts,tsx,js,jsx,cjs,mjs,json,css,scss,md,mdx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,cjs,mjs,json,css,scss,md,mdx}\" \"service/**/*.{ts,tsx,js,jsx,cjs,mjs,json,css,scss,md,mdx}\"",
    "lint": "eslint .",
    "lint:strict": "eslint . -c eslint.strict.config.js --max-warnings 0",
    "typecheck:strict": "tsc -p tsconfig.typecheck.strict.json --noEmit",
    "preview": "vite preview"
  },
